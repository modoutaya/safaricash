# SafariCash — environment variables (template).
# Copy to .env.local for local dev; never commit real values.
# Story that wires each var listed in trailing comment.

# Supabase (Story 1.2 — Supabase foundation)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase service-role key — server-side only (Edge Functions). NEVER ship to client.
SUPABASE_SERVICE_ROLE_KEY=

# SMS gateway — Termii (Story 6.1)
TERMII_API_KEY=

# Founder support contacts (used by Story 10.2 — dispute notify)
FOUNDER_SUPPORT_EMAIL=
FOUNDER_SUPPORT_PHONE=

# Edge Functions URL (used by Story 7.4 / 2.6 / 9.3 / 6.x to invoke
# /functions/v1/re-auth from the browser; format
# https://{project_ref}.supabase.co/functions/v1/). Story 1.3 added this.
SUPABASE_FUNCTIONS_URL=

# Cloudflare Worker rate-limit gateway (Story 1.4). When set, all
# /functions/v1/* calls go through the worker (which enforces 100 req/min/
# collector, NFR-S9). Leave EMPTY in dev to call Supabase directly and
# bypass rate-limiting. PRODUCTION MUST set this in Cloudflare Pages env.
# Format: https://safaricash-rate-limit.{cf-account}.workers.dev
VITE_SUPABASE_FUNCTIONS_GATEWAY_URL=

# Public-facing founder support phone shown in UI lockout copy
# (Story 1.3 — re-auth Edge Function). Falls back to a hardcoded MVP
# default if unset; production deploy MUST set this in Cloudflare Pages env.
VITE_FOUNDER_SUPPORT_PHONE=

# Receipt URL base (Story 6.7 — per-transaction share button).
# Story 6.4's Cloudflare Worker serves /r/{token}. The server-side SMS
# body builder reads `app.receipt_url_base` Postgres GUC; this VITE_* env
# var exposes the same base to the browser for the OS share sheet (no
# server round-trip needed). MUST match the server GUC. Default below is
# the production deploy target; override per environment.
VITE_RECEIPT_URL_BASE=https://safaricash.app/r

# (Removed in Story 1.5b — PRD v1.3 auth pivot.)
# AUTH_SMS_HOOK_SECRET was the HMAC key for the Send SMS Hook that
# dispatched login OTPs via Termii. The hook + OTP flow were decommissioned
# when the MVP auth path moved to Supabase-native signInWithPassword.
# Re-add if the hook is ever reinstated (trigger: Termii KYC clears).
