{
  "name": "safaricash",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SafariCash — Mobile-first PWA for collector-led tontine cycles",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test:edge": "./scripts/run-edge-tests.sh",
    "worker:rate-limit:dev": "wrangler dev --config workers/rate-limit/wrangler.toml --port 8787",
    "worker:rate-limit:check-config": "node workers/rate-limit/scripts/check-config.mjs",
    "worker:rate-limit:deploy": "node workers/rate-limit/scripts/check-config.mjs && wrangler deploy --config workers/rate-limit/wrangler.toml",
    "worker:rate-limit:tail": "wrangler tail --config workers/rate-limit/wrangler.toml",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --linked > src/infrastructure/supabase/database.types.ts",
    "provision-collector": "npx tsx scripts/provision-collector.ts",
    "reset-collector-password": "npx tsx scripts/reset-collector-password.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.99.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@cloudflare/workers-types": "^4.20260418.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.11.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "supabase": "^2.92.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
